{
  "name": "remembug-monorepo",
  "version": "0.1.0",
  "private": true,
  "description": "Remembug — a team knowledge base for Claude Code debugging sessions",
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "https://github.com/zaitanabil/remembug-cli.git"
  },
  "engines": {
    "node": ">=20"
  },
  "packageManager": "pnpm@9.12.3",
  "scripts": {
    "build": "pnpm -r --filter=./packages/* build",
    "typecheck": "pnpm -r --filter=./packages/* typecheck",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint .",
    "format": "prettier --write .",
    "format:check": "prettier --check ."
  },
  "devDependencies": {
    "@eslint/js": "^9.14.0",
    "@types/node": "^20.16.10",
    "eslint": "^9.14.0",
    "prettier": "^3.3.3",
    "tsx": "^4.19.2",
    "typescript": "^5.6.3",
    "typescript-eslint": "^8.13.0",
    "vitest": "^2.1.4"
  }
}
